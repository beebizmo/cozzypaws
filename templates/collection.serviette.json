{"sections":{"banner":{"type":"main-collection-banner","disabled":true,"settings":{"show_collection_description":true,"show_collection_image":true,"color_scheme":"scheme-d591d5c0-f7af-4280-bd26-676a440a87d5"}},"product-grid":{"type":"main-collection-product-grid","disabled":true,"settings":{"products_per_page":16,"columns_desktop":3,"columns_mobile":"2","color_scheme":"scheme-e80a2376-8c17-4c28-b17e-c1368ab8dbfe","image_ratio":"adapt","image_shape":"default","show_secondary_image":true,"show_vendor":false,"show_rating":false,"quick_add":"standard","enable_filtering":true,"filter_type":"horizontal","enable_sorting":true,"padding_top":36,"padding_bottom":36}},"custom_liquid_CaFGwg":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<!-- CozzyPaws — HERO VIDEO (TOWELS) -->\n<section id=\"cp-hero-towel\" class=\"color-scheme-1\">\n\n  <!-- Background video (Towels) -->\n  <video class=\"cp-hero__video\" autoplay loop muted playsinline preload=\"metadata\">\n    <source src=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/0934f188b5364ff7bfb038030ae8dfb2.mp4\" type=\"video\/mp4\">\n  <\/video>\n\n  <div class=\"cp-hero__overlay\" aria-hidden=\"true\"><\/div>\n\n  <!-- Content -->\n  <div class=\"cp-hero__content page-width\">\n    <h1 class=\"cp-hero__title h0\">\n      <strong>Le drap de bain préféré des chiens<\/strong><br>\n      Doux. Ultra-absorbant. Rapide.\n    <\/h1>\n\n    <p class=\"cp-hero__subtitle\">\n      La serviette CozzyPaws sèche en quelques minutes après le bain, la plage ou une balade sous la pluie —\n      et garde votre maison &amp; voiture propres.\n    <\/p>\n\n    <ul class=\"cp-hero__benefits\" role=\"list\">\n      <li><span class=\"cp-ico\">🧼<\/span> Moins d’odeurs &amp; d’humidité<\/li>\n      <li><span class=\"cp-ico\">🚗<\/span> Protège sièges &amp; canapé<\/li>\n      <li><span class=\"cp-ico\">🐶<\/span> Confort max (sans irriter)<\/li>\n    <\/ul>\n  <\/div>\n\n  <style>\n    \/* ====== Dawn-friendly video hero (TOWELS) ====== *\/\n    :root{\n      --cp-brand:#521010;\n      --cp-brand-hover:#732020;\n      --cp-light:#F1ECE6;\n    }\n\n    #cp-hero-towel{\n      position: relative;\n      overflow: hidden;\n      padding-top: clamp(88px, 14vh, 140px);\n      padding-bottom: clamp(40px, 12vh, 120px);\n      background: var(--color-background);\n      color: var(--color-foreground);\n      isolation: isolate;\n    }\n\n    \/* Background video *\/\n    #cp-hero-towel .cp-hero__video{\n      position: absolute;\n      inset: 0;\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      object-position: center;\n      z-index: -2;\n    }\n\n    \/* Stronger overlay (video is bright\/wet scenes) *\/\n    #cp-hero-towel .cp-hero__overlay{\n      position: absolute;\n      inset: 0;\n      background:\n        linear-gradient(to top, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.38) 45%, rgba(0,0,0,0.22) 100%);\n      z-index: -1;\n    }\n\n    \/* Content container *\/\n    #cp-hero-towel .cp-hero__content{\n      display: flex;\n      flex-direction: column;\n      align-items: flex-start;\n      justify-content: center;\n      gap: 1rem;\n      min-height: min(78vh, 760px);\n      max-width: 1200px;\n    }\n\n    \/* Headline *\/\n    #cp-hero-towel .cp-hero__title{\n      margin: 0;\n      color: #fff;\n      letter-spacing: -0.02em;\n      line-height: 1.06;\n      text-wrap: balance;\n      text-shadow: 0 3px 18px rgba(0,0,0,0.6);\n      max-width: 22ch;\n    }\n\n    \/* Subtitle *\/\n    #cp-hero-towel .cp-hero__subtitle{\n      margin: 0;\n      color: rgba(255,255,255,0.96);\n      text-shadow: 0 2px 12px rgba(0,0,0,0.55);\n      max-width: 60ch;\n    }\n\n    \/* Benefits pills *\/\n    #cp-hero-towel .cp-hero__benefits{\n      display: flex;\n      flex-wrap: wrap;\n      gap: .5rem;\n      margin: .75rem 0 0;\n      padding: 0;\n      color: #521010;\n    }\n\n    #cp-hero-towel .cp-hero__benefits li{\n      list-style: none;\n      display: inline-flex;\n      align-items: center;\n      gap: .5rem;\n      padding: .55rem .85rem;\n      border-radius: 999px;\n      border: 1px solid rgba(255,255,255,.28);\n      background: rgba(255,255,255,0.96);\n      backdrop-filter: blur(2px);\n      font-size: .95rem;\n      line-height: 1.2;\n      white-space: nowrap;\n    }\n\n    #cp-hero-towel .cp-ico{\n      font-size: 1.35rem;\n      line-height: 1;\n    }\n\n    \/* Mobile *\/\n    @media (max-width: 749px){\n      #cp-hero-towel .cp-hero__content{\n        align-items: center;\n        text-align: center;\n      }\n      #cp-hero-towel .cp-hero__benefits li{\n        white-space: normal;\n      }\n    }\n  <\/style>\n\n  <!-- Accessibility: pause animations for users who prefer reduced motion -->\n  <script>\n    (() => {\n      try {\n        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {\n          const v = document.querySelector('#cp-hero-towel .cp-hero__video');\n          if (v) { v.removeAttribute('autoplay'); v.pause?.(); }\n        }\n      } catch(e){}\n    })();\n  <\/script>\n\n<\/section>","color_scheme":"scheme-d591d5c0-f7af-4280-bd26-676a440a87d5","padding_top":0,"padding_bottom":0}},"custom_liquid_kq9Ccq":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"","color_scheme":"","padding_top":40,"padding_bottom":52}}},"order":["banner","product-grid","custom_liquid_CaFGwg","custom_liquid_kq9Ccq"]}