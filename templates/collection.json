rce src=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/0934f188b5364ff7bfb038030ae8dfb2.mp4\" type=\"video\/mp4\">\n  <\/video>\n\n  <div class=\"cp-hero__overlay\" aria-hidden=\"true\"><\/div>\n\n  <!-- Content -->\n  <div class=\"cp-hero__content page-width\">\n    <h1 class=\"cp-hero__title h0\">\n      <strong>Le drap de bain préféré des chiens<\/strong><br>\n      Doux. Ultra-absorbant. Rapide.\n    <\/h1>\n\n    <p class=\"cp-hero__subtitle\">\n      La serviette CozzyPaws sèche en quelques minutes après le bain, la plage ou une balade sous la pluie —\n      et garde votre maison &amp; voiture propres.\n    <\/p>\n\n    <ul class=\"cp-hero__benefits\" role=\"list\">\n      <li><span class=\"cp-ico\">🧼<\/span> Moins d’odeurs &amp; d’humidité<\/li>\n      <li><span class=\"cp-ico\">🚗<\/span> Protège sièges &amp; canapé<\/li>\n      <li><span class=\"cp-ico\">🐶<\/span> Confort max (sans irriter)<\/li>\n    <\/ul>\n  <\/div>\n\n  <style>\n    \/* ====== Dawn-friendly video hero (TOWELS) ====== *\/\n    :root{\n      --cp-brand:#521010;\n      --cp-brand-hover:#732020;\n      --cp-light:#F1ECE6;\n    }\n\n    #cp-hero-towel{\n      position: relative;\n      overflow: hidden;\n      padding-top: clamp(88px, 14vh, 140px);\n      padding-bottom: clamp(40px, 12vh, 120px);\n      background: var(--color-background);\n      color: var(--color-foreground);\n      isolation: isolate;\n    }\n\n    \/* Background video *\/\n    #cp-hero-towel .cp-hero__video{\n      position: absolute;\n      inset: 0;\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      object-position: center;\n      z-index: -2;\n    }\n\n    \/* Stronger overlay (video is bright\/wet scenes) *\/\n    #cp-hero-towel .cp-hero__overlay{\n      position: absolute;\n      inset: 0;\n      background:\n        linear-gradient(to top, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.38) 45%, rgba(0,0,0,0.22) 100%);\n      z-index: -1;\n    }\n\n    \/* Content container *\/\n    #cp-hero-towel .cp-hero__content{\n      display: flex;\n      flex-direction: column;\n      align-items: flex-start;\n      justify-content: center;\n      gap: 1rem;\n      min-height: min(78vh, 760px);\n      max-width: 1200px;\n    }\n\n    \/* Headline *\/\n    #cp-hero-towel .cp-hero__title{\n      margin: 0;\n      color: #fff;\n      letter-spacing: -0.02em;\n      line-height: 1.06;\n      text-wrap: balance;\n      text-shadow: 0 3px 18px rgba(0,0,0,0.6);\n      max-width: 22ch;\n    }\n\n    \/* Subtitle *\/\n    #cp-hero-towel .cp-hero__subtitle{\n      margin: 0;\n      color: rgba(255,255,255,0.96);\n      text-shadow: 0 2px 12px rgba(0,0,0,0.55);\n      max-width: 60ch;\n    }\n\n    \/* Benefits pills *\/\n    #cp-hero-towel .cp-hero__benefits{\n      display: flex;\n      flex-wrap: wrap;\n      gap: .5rem;\n      margin: .75rem 0 0;\n      padding: 0;\n      color: #521010;\n    }\n\n    #cp-hero-towel .cp-hero__benefits li{\n      list-style: none;\n      display: inline-flex;\n      align-items: center;\n      gap: .5rem;\n      padding: .55rem .85rem;\n      border-radius: 999px;\n      border: 1px solid rgba(255,255,255,.28);\n      background: rgba(255,255,255,0.96);\n      backdrop-filter: blur(2px);\n      font-size: .95rem;\n      line-height: 1.2;\n      white-space: nowrap;\n    }\n\n    #cp-hero-towel .cp-ico{\n      font-size: 1.35rem;\n      line-height: 1;\n    }\n\n    \/* Mobile *\/\n    @media (max-width: 749px){\n      #cp-hero-towel .cp-hero__content{\n        align-items: center;\n        text-align: center;\n      }\n      #cp-hero-towel .cp-hero__benefits li{\n        white-space: normal;\n      }\n    }\n  <\/style>\n\n  <!-- Accessibility: pause animations for users who prefer reduced motion -->\n  <script>\n    (() => {\n      try {\n        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {\n          const v = document.querySelector('#cp-hero-towel .cp-hero__video');\n          if (v) { v.removeAttribute('autoplay'); v.pause?.(); }\n        }\n      } catch(e){}\n    })();\n  <\/script>\n\n<\/section>","color_scheme":"","padding_top":0,"padding_bottom":0}},"custom_liquid_U3hDWt":{"type":"custom-liquid","disabled":true,"name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<!-- REVIEW BAR SECTION -->\n<div class=\"cp-reviewbar\">\n  <span class=\"cp-reviewbar-logo\">COZZYPAWS<\/span>\n  <span class=\"cp-reviewbar-stars\">★★★★★<\/span>\n  <span class=\"cp-reviewbar-text\">\n    Noté <strong>4,9\/5<\/strong> par plus de <strong>450 maîtres<\/strong> au Maroc\n  <\/span>\n<\/div>\n\n<style>\n\/* -----------------------------------------\n   REVIEW BAR — LAYOUT\n----------------------------------------- *\/\n.cp-reviewbar {\n  position: relative;\n  margin: 0 auto;\n  margin-top: 0;\n  width: 90%;\n  max-width: 1400px;\n  height: 30px;\n\n  background: #521010;\n  border-radius: 0;\n\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 10px;\n\n  color: #ffffff;\n  font-size: 20px;\n  line-height: 1;\n  letter-spacing: 0.2px;\n\n  \/* Entrance animation *\/\n  opacity: 0;\n  transform: translateY(-8px);\n  animation: cp-bar-fade 0.9s ease-out forwards;\n  animation-delay: 0.3s;\n}\n\n\/* -----------------------------------------\n   ELEMENTS\n----------------------------------------- *\/\n.cp-reviewbar-logo {\n  font-weight: 600;\n  opacity: 0.95;\n  font-size: 13px;\n\n  \/* shimmer animation *\/\n  background: linear-gradient(90deg, #ffffff, #cccccc, #ffffff);\n  background-size: 200% auto;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  animation: cp-shimmer 4s linear infinite;\n}\n\n.cp-reviewbar-stars {\n  color: #ffb545;\n  font-size: 14px;\n  letter-spacing: 1px;\n\n  \/* sparkling\/pulsing stars *\/\n  animation: cp-stars-pulse 1.8s ease-in-out infinite;\n}\n\n.cp-reviewbar-text strong {\n  font-weight: 600;\n}\n\n\/* -----------------------------------------\n   ANIMATIONS\n----------------------------------------- *\/\n\n\/* Fade + slide from top *\/\n@keyframes cp-bar-fade {\n  0% {\n    opacity: 0;\n    transform: translateY(-8px);\n  }\n  100% {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n\/* Text shimmer effect *\/\n@keyframes cp-shimmer {\n  0% { background-position: 200% center; }\n  100% { background-position: -200% center; }\n}\n\n\/* Soft star pulsing *\/\n@keyframes cp-stars-pulse {\n  0%, 100% { opacity: 1; transform: scale(1); }\n  50%      { opacity: 0.8; transform: scale(1.08); }\n}\n\n\/* -----------------------------------------\n   MOBILE\n----------------------------------------- *\/\n@media (max-width: 749px) {\n  .cp-reviewbar {\n    width: 92%;\n    height: auto;\n    padding: 6px 10px;\n    flex-wrap: wrap;\n    text-align: center;\n    font-size: 13px;\n  }\n}\n\n\/* -----------------------------------------\n   REMOVE WHITE SPACES\n----------------------------------------- *\/\n.section-template--custom-liquid {\n  padding-top: 0 !important;\n  padding-bottom: 0 !important;\n  margin-top: 0 !important;\n  margin-bottom: 0 !important;\n}\n\n.shopify-section {\n  margin-top: 0 !important;\n}\n\n#cp-hero {\n  padding-bottom: 0 !important;\n  margin-bottom: 0 !important;\n}\n<\/style>","color_scheme":"scheme-d591d5c0-f7af-4280-bd26-676a440a87d5","padding_top":0,"padding_bottom":0}},"custom_liquid_VbBeEP":{"type":"custom-liquid","disabled":true,"name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<!-- CozzyPaws — ADVANTAGES (TOWELS) -->\n<section class=\"cp-advantages\">\n  <div class=\"page-width cp-advantages__inner\">\n\n    <h2 class=\"cp-advantages__title\">\n      Encore plus de douceur,<br>\n      pour vous et votre chien 🐾\n    <\/h2>\n\n    <p class=\"cp-advantages__lead\">\n      <strong>Sécher vite, bien et sans stress.<\/strong><br>\n      Les <strong>serviettes CozzyPaws<\/strong> sont conçues pour absorber efficacement l’eau,\n      le sable et la boue après le bain, la plage ou la balade —\n      to