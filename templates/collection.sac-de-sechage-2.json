istener('mouseleave', ()=>{ isDown=false; });\n      track.addEventListener('mousemove', (e)=>{\n        if(!isDown) return;\n        e.preventDefault();\n        const x = e.pageX;\n        const walk = (x - startX);\n        track.scrollLeft = scrollLeft - walk;\n      });\n    }\n\n    function boot(){\n      document.querySelectorAll('[data-cp-realreviews]').forEach(init);\n    }\n\n    if(document.readyState === 'loading'){\n      document.addEventListener('DOMContentLoaded', boot);\n    } else {\n      boot();\n    }\n\n    \/\/ Shopify theme editor support\n    document.addEventListener('shopify:section:load', (e)=>{\n      const root = e.target && e.target.querySelector ? e.target.querySelector('[data-cp-realreviews]') : null;\n      if(root) init(root);\n    });\n  })();\n<\/script>","color_scheme":"scheme-d591d5c0-f7af-4280-bd26-676a440a87d5","padding_top":0,"padding_bottom":0}},"image_banner_FXjMMf":{"type":"image-banner","name":"4","settings":{"image":"shopify:\/\/shop_images\/2_copy.png","image_overlay_opacity":0,"image_height":"adapt","image_behavior":"none","desktop_content_position":"middle-center","desktop_content_alignment":"center","show_text_box":true,"color_scheme":"","stack_images_on_mobile":true,"mobile_content_alignment":"center","show_text_below":true}},"featured_product_cpDt9U":{"type":"featured-product","blocks":{"text_4FYFiq":{"type":"text","settings":{"text":"{{ section.settings.product.vendor }}","text_style":"uppercase"}},"title_h8iwXb":{"type":"title","settings":{"heading_size":"h1"}},"price_k6rpcx":{"type":"price","settings":{}},"variant_picker_YPQdMt":{"type":"variant_picker","settings":{"picker_type":"button","swatch_shape":"circle"}},"quantity_selector_P6qhke":{"type":"quantity_selector","settings":{}},"buy_buttons_FpY8ct":{"type":"buy_buttons","settings":{"show_dynamic_checkout":true,"show_gift_card_recipient":true}},"share_BEerqW":{"type":"share","settings":{"share_label":"Partager"}}},"block_order":["text_4FYFiq","title_h8iwXb"