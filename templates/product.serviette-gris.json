olor-background);\n      color: var(--color-foreground);\n      isolation: isolate;\n    }\n\n    \/* Background video *\/\n    #cp-hero-towel .cp-hero__video{\n      position: absolute;\n      inset: 0;\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      object-position: center;\n      z-index: -2;\n    }\n\n    \/* Stronger overlay (video is bright\/wet scenes) *\/\n    #cp-hero-towel .cp-hero__overlay{\n      position: absolute;\n      inset: 0;\n      background:\n        linear-gradient(to top, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.38) 45%, rgba(0,0,0,0.22) 100%);\n      z-index: -1;\n    }\n\n    \/* Content container *\/\n    #cp-hero-towel .cp-hero__content{\n      display: flex;\n      flex-direction: column;\n      align-items: flex-start;\n      justify-content: center;\n      gap: 1rem;\n      min-height: min(78vh, 760px);\n      max-width: 1200px;\n    }\n\n    \/* Headline *\/\n    #cp-hero-towel .cp-hero__title{\n      margin: 0;\n      color: #fff;\n      letter-spacing: -0.02em;\n      line-height: 1.06;\n      text-wrap: balance;\n      text-shadow: 0 3px 18px rgba(0,0,0,0.6);\n      max-width: 22ch;\n    }\n\n    \/* Subtitle *\/\n    #cp-hero-towel .cp-hero__subtitle{\n      margin: 0;\n      color: rgba(255,255,255,0.96);\n      text-shadow: 0 2px 12px rgba(0,0,0,0.55);\n      max-width: 60ch;\n    }\n\n    \/* Benefits pills *\/\n    #cp-hero-towel .cp-hero__benefits{\n      display: flex;\n      flex-wrap: wrap;\n      gap: .5rem;\n      margin: .75rem 0 0;\n      padding: 0;\n      color: #521010;\n    }\n\n    #cp-hero-towel .cp-hero__benefits li{\n      list-style: none;\n      display: inline-flex;\n      align-items: center;\n      gap: .5rem;\n      padding: .55rem .85rem;\n      border-radius: 999px;\n      border: 1px solid rgba(255,255,255,.28);\n      background: rgba(255,255,255,0.96);\n      backdrop-filter: blur(2px);\n      font-size: .95rem;\n      line-height: 1.2;\n      white-space: nowrap;\n    }\n\n    #cp