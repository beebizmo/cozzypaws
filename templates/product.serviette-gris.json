alt=\"Retour 7 jours\" loading=\"lazy\">\n        <strong>Retour 7 jours<\/strong>\n        <small>Simple & rapide<\/small>\n      <\/div>\n\n      <div class=\"cp-trust-item\">\n        <img class=\"cp-icon-img\"\n          src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/1_d71777e0-fcc9-4083-a9d1-95ea040c3173.png?v=1769615741\"\n          alt=\"Support réactif\" loading=\"lazy\">\n        <strong>Support réactif<\/strong>\n        <small>WhatsApp<\/small>\n      <\/div>\n\n      <div class=\"cp-trust-item\">\n        <img class=\"cp-icon-img\"\n          src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/2_7c961e91-aeb2-4986-8ffe-1864b716d7a8.png?v=1769615741\"\n          alt=\"Paiement à la livraison\" loading=\"lazy\">\n        <strong>Paiement à la livraison<\/strong>\n        <small>Partout au Maroc<\/small>\n      <\/div>\n\n    <\/div>\n  <\/div>\n\n  <style>\n    .cp-trust-clean{\n      padding: clamp(26px, 3vw, 44px) 0;\n    }\n\n    .cp-trust-grid{\n      display: grid;\n      grid-template-columns: repeat(4, minmax(0,1fr));\n      gap: clamp(28px, 3vw, 48px);\n      text-align: center;\n      align-items: start;\n    }\n\n    .cp-trust-item{\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n    }\n\n    \/* 🔥 BIG CIRCULAR ICON (IMAGE ITSELF) *\/\n    .cp-icon-img{\n      width: 110px;        \/* ⬅️ BIGGER ICON *\/\n      height: 110px;\n      border-radius: 50%;  \/* makes image circular *\/\n      object-fit: cover;   \/* perfect crop *\/\n      display: block;\n      margin-bottom: 16px;\n    }\n\n    .cp-trust-item strong{\n      font-size: 15px;\n      font-weight: 700;\n      color: #ffffff;\n      margin-bottom: 4px;\n    }\n\n    .cp-trust-item small{\n      font-size: 13px;\n      color: rgba(255,255,255,.75);\n    }\n\n    \/* Responsive *\/\n    @media (max-width: 990px){\n      .cp-trust-grid{\n        grid-template-columns: repeat(2,1fr);\n        row-gap: 36px;\n      }\n    }\n\n    @media (max-width: 520px){\n      .cp-trust-grid{\n        grid-template-columns: 1fr;\n      }\n    }\n  <\/style>\n<\/section>","color_scheme":"scheme-095c3560-da68-4939-b41f-087b8dd43596","padding_top":0,"padding_bottom":0}},"custom_liquid_bzMdDX":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<!-- CozzyPaws — TEXT REVIEWS SLIDER (TOWELS \/ NO PICTURES) -->\n<section class=\"cp-towelreviews\" data-cp-towelreviews>\n  <div class=\"page-width cp-towelreviews__wrap\">\n    <div class=\"cp-towelreviews__header\">\n      <h2 class=\"cp-towelreviews__title\">Avis sur nos serviettes CozzyPaws<\/h2>\n      <p class=\"cp-towelreviews__subtitle\">Retours authentiques — douceur, absorption, gain de temps.<\/p>\n    <\/div>\n\n    <div class=\"cp-towelreviews__slider\" aria-label=\"Avis clients serviettes\">\n      <button class=\"cp-towelreviews__nav cp-towelreviews__nav--prev\" type=\"button\" aria-label=\"Avis précédents\">‹<\/button>\n\n      <div class=\"cp-towelreviews__track\" data-cp-track tabindex=\"0\">\n        <!-- Review 1 -->\n        <article class=\"cp-trv\" aria-label=\"Avis 1\">\n          <div class=\"cp-trv__body\">\n            <div class=\"cp-trv__top\">\n              <div class=\"cp-trv__name\">Imane A.<\/div>\n              <div class=\"cp-trv__date\">12\/2025<\/div>\n            <\/div>\n\n            <div class=\"cp-trv__stars\" aria-label=\"5 étoiles sur 5\">\n              <span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span>\n            <\/div>\n\n            <p class=\"cp-trv__text\">\n              J’ai remplacé toutes mes serviettes ordinaires. Celle-ci absorbe vraiment vite, surtout avec les poils longs.\n              Après le bain, c’est beaucoup plus simple et la maison reste propre.\n            <\/p>\n\n            <div class=\"cp-trv__meta\">\n              <span class=\"cp-trv__verified\">✓<\/span><span>Vérifié<\/span>\n              <span class=\"cp-trv__tag\">50×70<\/span>\n            <\/div>\n          <\/div>\n        <\/article>\n\n        <!-- Review 2 -->\n        <article class=\"cp-trv\" aria-label=\"Avis 2\">\n          <div class=\"cp-trv__body\">\n            <div class=\"cp-trv__top\">\n              <div class=\"cp-trv__name\">Yassine K.<\/div>\n              <div class=\"cp-trv__date\">11\/2025<\/div>\n            <\/div>\n\n            <div class=\"cp-trv__stars\" aria-label=\"5 étoiles sur 5\">\n              <span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span>\n            <\/div>\n\n            <p class=\"cp-trv__text\">\n              Super pratique après une balade sous la pluie. Je sèche mon spitz en 2 minutes, et fini les sièges mouillés dans la voiture.\n              Très douce, mon chien se laisse faire sans stress.\n            <\/p>\n\n            <div class=\"cp-trv__meta\">\n              <span class=\"cp-trv__verified\">✓<\/span><span>Vérifié<\/span>\n              <span class=\"cp-trv__tag\">Voiture<\/span>\n            <\/div>\n          <\/div>\n        <\/article>\n\n        <!-- Review 3 -->\n        <article class=\"cp-trv\" aria-label=\"Avis 3\">\n          <div class=\"cp-trv__body\">\n            <div class=\"cp-trv__top\">\n              <div class=\"cp-trv__name\">Salma R.<\/div>\n              <div class=\"cp-trv__date\">10\/2025<\/div>\n            <\/div>\n\n            <div class=\"cp-trv__stars\" aria-label=\"5 étoiles sur 5\">\n              <span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span>\n            <\/div>\n\n            <p class=\"cp-trv__text\">\n              On l’utilise aussi à la plage : sable + eau = catastrophe avant… maintenant je le sèche à l’extérieur et je secoue la serviette.\n              Résultat : moins de sable à la maison.\n            <\/p>\n\n            <div class=\"cp-trv__meta\">\n              <span class=\"cp-trv__verified\">✓<\/span><span>Vérifié<\/span>\n              <span class=\"cp-trv__tag\">Plage<\/span>\n            <\/div>\n          <\/div>\n        <\/article>\n\n        <!-- Review 4 -->\n        <article class=\"cp-trv\" aria-label=\"Avis 4\">\n          <div class=\"cp-trv__body\">\n            <div class=\"cp-trv__top\">\n              <div class=\"cp-trv__name\">Hajar B.<\/div>\n              <div class=\"cp-trv__date\">09\/2025<\/div>\n            <\/div>\n\n            <div class=\"cp-trv__stars\" aria-label=\"5 étoiles sur 5\">\n              <span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span>\n            <\/div>\n\n            <p class=\"cp-trv__text\">\n              Le tissu est épais, doux et ne “gratte” pas. Mon caniche adore se poser dessus après le bain.\n              Très bonne qualité, ça fait vraiment premium.\n            <\/p>\n\n            <div class=\"cp-trv__meta\">\n              <span class=\"cp-trv__verified\">✓<\/span><span>Vérifié<\/span>\n              <span class=\"cp-trv__tag\">Confort<\/span>\n            <\/div>\n          <\/div>\n        <\/article>\n\n        <!-- Review 5 -->\n        <article class=\"cp-trv\" aria-label=\"Avis 5\">\n          <div class=\"cp-trv__body\">\n            <div class=\"cp-trv__top\">\n              <div class=\"cp-trv__name\">Nora M.<\/div>\n              <div class=\"cp-trv__date\">08\/2025<\/div>\n            <\/div>\n\n            <div class=\"cp-trv__stars\" aria-label=\"5 étoiles sur 5\">\n              <span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span>\n            <\/div>\n\n            <p class=\"cp-trv__text\">\n              J’ai pris 2 tailles. Une pour sécher, une pour mettre sur le canapé. Absorption top, et surtout ça sèche vite après lavage.\n              Indispensable si vous avez un chien qui perd beaucoup ses poils.\n            <\/p>\n\n            <div class=\"cp-trv__meta\">\n              <span class=\"cp-trv__verified\">✓<\/span><span>Vérifié<\/span>\n              <span class=\"cp-trv__tag\">Maison<\/span>\n            <\/div>\n          <\/div>\n        <\/article>\n      <\/div>\n\n      <button class=\"cp-towelreviews__nav cp-towelreviews__nav--next\" type=\"button\" aria-label=\"Avis suivants\">›<\/button>\n    <\/div>\n  <\/div>\n<\/section>\n\n<style>\n  .cp-towelreviews{ padding: 54px 0; }\n  .cp-towelreviews__header{ margin-bottom: 14px; }\n  .cp-towelreviews__title{\n    margin:0 0 6px;\n    font-weight: 800;\n    font-size: clamp(20px, 2.4vw, 28px);\n  }\n  .cp-towelreviews__subtitle{ margin:0; color: rgba(0,0,0,.55); font-size: 14px; }\n\n  .cp-towelreviews__slider{ position: relative; }\n  .cp-towelreviews__track{\n    display:flex;\n    gap: 14px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    scroll-behavior: smooth;\n    padding: 10px 48px;\n    scrollbar-width: none;\n    -webkit-overflow-scrolling: touch;\n  }\n  .cp-towelreviews__track::-webkit-scrollbar{ display:none; }\n\n  \/* Card (no image) *\/\n  .cp-trv{\n    flex: 0 0 520px;\n    scroll-snap-align: start;\n    border: 1px solid rgba(0,0,0,.08);\n    border-radius: 18px;\n    background: #fff;\n    overflow: hidden;\n    min-height: 220px;\n  }\n  .cp-trv__body{\n    padding: 16px;\n    display:flex;\n    flex-direction:column;\n    gap: 10px;\n    height: 100%;\n  }\n\n  .cp-trv__top{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap: 10px;\n  }\n  .cp-trv__name{ font-weight: 800; }\n  .cp-trv__date{ font-size: 12px; color: rgba(0,0,0,.45); }\n\n  .cp-trv__stars{ font-size: 14px; line-height: 1; }\n  .cp-star{ color: #f5a623; }\n\n  .cp-trv__text{\n    margin:0;\n    font-size: 14px;\n    line-height: 1.6;\n    color: rgba(0,0,0,.72);\n  }\n\n  .cp-trv__meta{\n    margin-top: auto;\n    display:flex;\n    align-items:center;\n    gap: 8px;\n    font-size: 12px;\n    color: rgba(0,0,0,.55);\n  }\n  .cp-trv__verified{\n    width:18px; height:18px;\n    border-radius: 999px;\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    background: rgba(0,0,0,.08);\n    color: rgba(0,0,0,.75);\n    font-size: 12px;\n  }\n  .cp-trv__tag{\n    margin-left: auto;\n    font-weight: 700;\n    color: rgba(0,0,0,.55);\n  }\n\n  .cp-towelreviews__nav{\n    position:absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 34px;\n    height: 34px;\n    border-radius: 999px;\n    border: 1px solid rgba(0,0,0,.12);\n    background: #fff;\n    cursor:pointer;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-size: 20px;\n    line-height: 1;\n    box-shadow: 0 6px 18px rgba(0,0,0,.08);\n    z-index: 2;\n  }\n  .cp-towelreviews__nav--prev{ left: 8px; }\n  .cp-towelreviews__nav--next{ right: 8px; }\n\n  @media (max-width: 989px){\n    .cp-trv{ flex-basis: 86vw; }\n    .cp-towelreviews__track{ padding: 10px 44px; }\n  }\n<\/style>\n\n<script>\n(function(){\n  function init(root){\n    const track = root.querySelector('[data-cp-track]');\n    const prev  = root.querySelector('.cp-towelreviews__nav--prev');\n    const next  = root.querySelector('.cp-towelreviews__nav--next');\n    if(!track || !prev || !next) return;\n\n    const step = () => {\n      const card = track.querySelector('.cp-trv');\n      if(!card) return 520;\n      const gap = 14;\n      return card.getBoundingClientRect().width + gap;\n    };\n\n    prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));\n    next.addEventListener('click', () => track.scrollBy({ left:  step(), behavior: 'smooth' }));\n\n    \/* Drag to scroll (desktop) *\/\n    let isDown=false, startX=0, scrollLeft=0;\n    track.addEventListener('mousedown', (e)=>{\n      isDown=true;\n      startX=e.pageX;\n      scrollLeft=track.scrollLeft;\n    });\n    window.addEventListener('mouseup', ()=>{ isDown=false; });\n    track.addEventListener('mouseleave', ()=>{ isDown=false; });\n    track.addEventListener('mousemove', (e)=>{\n      if(!isDown) return;\n      e.preventDefault();\n      const walk = (e.pageX - startX);\n      track.scrollLeft = scrollLeft - walk;\n    });\n  }\n\n  function boot(){\n    document.querySelectorAll('[data-cp-towelreviews]').forEach(init);\n  }\n\n  if(document.readyState === 'loading'){\n    document.addEventListener('DOMContentLoaded', boot);\n  } else {\n    boot();\n  }\n\n  document.addEventListener('shopify:section:load', (e)=>{\n    const root = e.target && e.target.querySelector ? e.target.querySelector('[data-cp-towelreviews]') : null;\n    if(root) init(root);\n  });\n})();\n<\/script>","color_scheme":"scheme-d591d5c0-f7af-4280-bd26-676a440a87d5","padding_top":0,"padding_bottom":0}},"custom_liquid_kwEXKz":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<!-- ====== CozzyPaws — Trust Events Gallery (Combined, modern) ====== -->\n<section class=\"cp-trust-events color-background-1\" data-cp-trust-events>\n  <div class=\"page-width\">\n\n    <div class=\"cp-trust-events__header\">\n      \n      <h2 class=\"cp-trust-events__title\">Ils nous ont vus en vrai 🐾<\/h2>\n      <p class=\"cp-trust-events__subtitle\">\n        CozzyPaws, une marque à l’écoute de ses clients, testée dans la vraie vie.\n      <\/p>\n    <\/div>\n\n    <div class=\"cp-trust-events__tabs\" role=\"tablist\" aria-label=\"Événements CozzyPaws\">\n      <button class=\"cp-trust-events__tab is-active\" type=\"button\" role=\"tab\" aria-selected=\"true\" aria-controls=\"cp-event-1\" data-cp-tab=\"1\">\n        Événement équestre\n      <\/button>\n      <button class=\"cp-trust-events__tab\" type=\"button\" role=\"tab\" aria-selected=\"false\" aria-controls=\"cp-event-2\" data-cp-tab=\"2\">\n        Expo canine\n      <\/button>\n    <\/div>\n\n    <!-- ===== Event 1 ===== -->\n    <div id=\"cp-event-1\" class=\"cp-trust-events__panel is-active\" role=\"tabpanel\" aria-labelledby=\"cp-event-1-tab\" data-cp-panel=\"1\">\n      <div class=\"cp-trust-events__eventhead\">\n        <div class=\"cp-trust-events__badge\">Événement équestre 2025<\/div>\n        <h3 class=\"cp-trust-events__eventtitle\">Coupe du Trône – Club Équestre de Oued Ykem<\/h3>\n        <p class=\"cp-trust-events__eventsub\">\n          Une journée exceptionnelle aux côtés des cavaliers, des familles et de leurs compagnons à quatre pattes.\n        <\/p>\n      <\/div>\n\n      <div class=\"cp-trust-events__grid\">\n        {% assign gallery_string_1 = \"\nhttps:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/WhatsApp_Image_2025-11-29_at_18.58.50.jpg?v=1764725159|\nhttps:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/WhatsApp_Image_2025-11-29_at_18.58.09_1.jpg?v=1764725158|\nhttps:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/WhatsApp_Image_2025-11-29_at_18.57.55.jpg?v=1764725157|\nhttps:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/WhatsApp_Image_2025-11-29_at_18.58.10.jpg?v=1764725157|\nhttps:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/WhatsApp_Image_2025-11-29_at_18.58.10_3.jpg?v=1764725157|\nhttps:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/WhatsApp_Image_2025-11-29_at_18.58.10_2.jpg?v=1764725157|\nhttps:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/WhatsApp_Image_2025-11-28_at_14.47.49_1.jpg?v=1764725149\n\" %}\n        {% assign gallery_1 = gallery_string_1 | split: \"|\" %}\n        {% for pic in gallery_1 %}\n          {% assign pic_trim = pic | strip %}\n          {% if pic_trim != \"\" %}\n            <figure class=\"cp-trust-events__item\">\n              <div class=\"cp-trust-events__imgwrap\">\n                <img\n                  src=\"{{ pic_trim }}\"\n                  alt=\"CozzyPaws – photos de l’événement équestre\"\n                  loading=\"lazy\"\n                  class=\"cp-trust-events__img\"\n                >\n              <\/div>\n            <\/figure>\n          {% endif %}\n        {% endfor %}\n      <\/div>\n    <\/div>\n\n    <!-- ===== Event 2 ===== -->\n    <div id=\"cp-event-2\" class=\"cp-trust-events__panel\" role=\"tabpanel\" aria-labelledby=\"cp-event-2-tab\" data-cp-panel=\"2\" hidden>\n      <div class=\"cp-trust-events__eventhead\">\n        <div class=\"cp-trust-events__badge\">Expo canine 2025<\/div>\n        <h3 class=\"cp-trust-events__eventtitle\">Exposition Canine – Novembre 2025<\/h3>\n        <p class=\"cp-trust-events__eventsub\">\n          Quelques moments avec les chiens, les toiletteurs et les passionnés qui ont découvert nos produits.\n        <\/p>\n      <\/div>\n\n      <div class=\"cp-trust-events__grid\">\n        {% assign gallery_string_2 = \"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/7_1f4e96d3-e08a-4c30-ad00-654d5efc587f.png?v=1764096843|https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/2_7ae83911-f0f3-4f45-b381-21a237044245.png?v=1764096862|https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/3_cdd2809c-cb9e-48c4-b19c-0b973dd37c67.png?v=1764096873|https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/canin.png?v=1764097205|https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/6_ffb535d8-8535-4b7f-a259-60feb2d75ae5.png?v=1764096868|https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/5_d5316fa5-602e-45f4-936e-df73abb7e6f3.png?v=1764096866|https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/4_a4ddb230-de01-418d-a75b-90d43085b7b4.png?v=1764096877\" %}\n        {% assign gallery_2 = gallery_string_2 | split: \"|\" %}\n        {% for pic in gallery_2 %}\n          {% assign pic_trim = pic | strip %}\n          {% if pic_trim != \"\" %}\n            <figure class=\"cp-trust-events__item\">\n              <div class=\"cp-trust-events__imgwrap\">\n                <img\n                  src=\"{{ pic_trim }}\"\n                  alt=\"CozzyPaws – photos de l’expo canine\"\n                  loading=\"lazy\"\n                  class=\"cp-trust-events__img\"\n                >\n              <\/div>\n            <\/figure>\n          {% endif %}\n        {% endfor %}\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <style>\n    \/* ====== Trust Events (modern, Dawn-friendly) ====== *\/\n    .cp-trust-events{\n      padding-block: clamp(34px, 5vw, 70px);\n    }\n\n    .cp-trust-events__header{\n      text-align:center;\n      max-width: 820px;\n      margin: 0 auto clamp(18px, 3vw, 28px);\n    }\n\n    .cp-trust-events__pill{\n      display:inline-flex;\n      align-items:center;\n      gap: 8px;\n      padding: 6px 14px;\n      border-radius: 999px;\n      font-size: 12px;\n      letter-spacing: .08em;\n      text-transform: uppercase;\n      background: rgba(0,0,0,.05);\n    }\n    .cp-trust-events__pill::before{ content:\"✓\"; font-weight: 900; }\n\n    .cp-trust-events__title{\n      margin: 10px 0 6px;\n      font-size: clamp(22px, 1.1rem + 1.2vw, 34px);\n      line-height: 1.15;\n      font-weight: 900;\n    }\n\n    .cp-trust-events__subtitle{\n      margin: 0;\n      opacity: .75;\n      font-size: 15px;\n      line-height: 1.6;\n    }\n\n    \/* Tabs *\/\n    .cp-trust-events__tabs{\n      display:flex;\n      gap: 10px;\n      justify-content:center;\n      flex-wrap: wrap;\n      margin: 18px 0 8px;\n    }\n\n    .cp-trust-events__tab{\n      appearance:none;\n      border: 1px solid rgba(0,0,0,.12);\n      background: rgba(255,255,255,.7);\n      padding: 10px 14px;\n      border-radius: 999px;\n      font-weight: 800;\n      font-size: 13px;\n      cursor:pointer;\n      transition: transform .15s ease, background .15s ease, border-color .15s ease;\n    }\n    .cp-trust-events__tab:hover{ transform: translateY(-1px); }\n    .cp-trust-events__tab.is-active{\n      background: #451318;\n      color: #fff;\n      border-color: rgba(0,0,0,.0);\n    }\n    .cp-trust-events__tab:focus-visible{\n      outline: 2px solid rgba(69,19,24,.55);\n      outline-offset: 3px;\n    }\n\n    \/* Event header block *\/\n    .cp-trust-events__eventhead{\n      max-width: 900px;\n      margin: 0 auto clamp(14px, 2vw, 18px);\n      text-align:center;\n      background: rgba(0,0,0,.03);\n      border: 1px solid rgba(0,0,0,.08);\n      border-radius: 18px;\n      padding: clamp(14px, 2.5vw, 18px);\n    }\n\n    .cp-trust-events__badge{\n      display:inline-flex;\n      align-items:center;\n      gap: 8px;\n      font-size: 12px;\n      font-weight: 900;\n      letter-spacing: .08em;\n      text-transform: uppercase;\n      opacity: .8;\n      margin-bottom: 6px;\n    }\n    .cp-trust-events__badge::before{ content:\"🐾\"; }\n\n    .cp-trust-events__eventtitle{\n      margin: 0 0 6px;\n      font-size: clamp(18px, 1rem + .9vw, 24px);\n      line-height: 1.25;\n      font-weight: 900;\n    }\n\n    .cp-trust-events__eventsub{\n      margin: 0;\n      opacity: .75;\n      font-size: 14px;\n      line-height: 1.6;\n    }\n\n    \/* Grid *\/\n    .cp-trust-events__grid{\n      display:grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: clamp(10px, 1.8vw, 16px);\n      margin-top: 14px;\n    }\n    @media (min-width: 750px){\n      .cp-trust-events__grid{ grid-template-columns: repeat(3, minmax(0, 1fr)); }\n    }\n    @media (min-width: 1100px){\n      .cp-trust-events__grid{ grid-template-columns: repeat(4, minmax(0, 1fr)); }\n    }\n\n    .cp-trust-events__item{ margin:0; }\n\n    .cp-trust-events__imgwrap{\n      position:relative;\n      overflow:hidden;\n      border-radius: 18px;\n      aspect-ratio: 4 \/ 5;\n      background: #f3ece5;\n      border: 1px solid rgba(0,0,0,.06);\n    }\n\n    .cp-trust-events__img{\n      width:100%;\n      height:100%;\n      object-fit: cover;\n      display:block;\n      transition: transform .35s ease, filter .35s ease;\n    }\n\n    .cp-trust-events__imgwrap::after{\n      content:\"\";\n      position:absolute;\n      inset:0;\n      pointer-events:none;\n      background: radial-gradient(circle at top left, rgba(0,0,0,0.05), transparent 58%);\n      opacity: 0;\n      transition: opacity .35s ease;\n    }\n\n    .cp-trust-events__imgwrap:hover .cp-trust-events__img{\n      transform: scale(1.04);\n      filter: saturate(1.05);\n    }\n    .cp-trust-events__imgwrap:hover::after{ opacity: 1; }\n\n    \/* Panels *\/\n    .cp-trust-events__panel[hidden]{ display:none !important; }\n\n    \/* Reduced motion *\/\n    @media (prefers-reduced-motion: reduce){\n      .cp-trust-events__img{ transition:none; }\n      .cp-trust-events__tab{ transition:none; }\n      .cp-trust-events__imgwrap::after{ transition:none; }\n    }\n  <\/style>\n\n  <script>\n    (function(){\n      function init(root){\n        const tabs = root.querySelectorAll('[data-cp-tab]');\n        const panels = root.querySelectorAll('[data-cp-panel]');\n        if(!tabs.length || !panels.length) return;\n\n        function activate(id){\n          tabs.forEach(t=>{\n            const on = t.getAttribute('data-cp-tab') === id;\n            t.classList.toggle('is-active', on);\n            t.setAttribute('aria-selected', on ? 'true' : 'false');\n          });\n          panels.forEach(p=>{\n            const on = p.getAttribute('data-cp-panel') === id;\n            p.classList.toggle('is-active', on);\n            if(on){ p.removeAttribute('hidden'); }\n            else{ p.setAttribute('hidden',''); }\n          });\n        }\n\n        tabs.forEach(btn=>{\n          btn.addEventListener('click', ()=> activate(btn.getAttribute('data-cp-tab')));\n        });\n      }\n\n      function boot(){\n        document.querySelectorAll('[data-cp-trust-events]').forEach(init);\n      }\n\n      if(document.readyState === 'loading'){\n        document.addEventListener('DOMContentLoaded', boot);\n      } else {\n        boot();\n      }\n\n      document.addEventListener('shopify:section:load', function(e){\n        const root = e.target && e.target.querySelector ? e.target.querySelector('[data-cp-trust-events]') : null;\n        if(root) init(root);\n      });\n    })();\n  <\/script>\n<\/section>","color_scheme":"scheme-d591d5c0-f7af-4280-bd26-676a440a87d5","padding_top":0,"padding_bottom":0}},"custom_liquid_EcDkyH":{"type":"custom-liquid","name":"reviews","settings":{"custom_liquid":"<!-- ====== Vu dans \/ Known from (Custom Liquid block) ====== -->\n<section id=\"seen-in\" class=\"cp-seen-in color-background-1\">\n  <div class=\"page-width\">\n\n    <!-- Title -->\n    <h2 class=\"cp-title\">Testé et recommandé par<\/h2>\n\n    <!-- Logos row -->\n    <div class=\"cp-logos\" role=\"list\" aria-label=\"Media logos\">\n      <div class=\"cp-logo\" role=\"listitem\">\n        <img\n          src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/2_58c5760c-8c8a-44e6-8c65-8b244027e333.png?v=1759232831\"\n          alt=\"\"\n          loading=\"lazy\"\n          decoding=\"async\"\n        \/>\n      <\/div>\n\n      <div class=\"cp-logo\" role=\"listitem\">\n        <img\n          src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/Plan-de-travail-1annuaire-canin-e1715608288468.png?v=1764971952\"\n          alt=\"\"\n          loading=\"lazy\"\n          decoding=\"async\"\n        \/>\n      <\/div>\n\n      <div class=\"cp-logo\" role=\"listitem\">\n        <img\n          src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/Untitled_design_-_2026-01-28T171213.517.png?v=1769616757?v=1759232831\"\n          alt=\"Dogs\"\n          loading=\"lazy\"\n          decoding=\"async\"\n        \/>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <styl