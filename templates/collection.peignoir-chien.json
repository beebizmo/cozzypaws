{"sections":{"banner":{"type":"main-collection-banner","disabled":true,"settings":{"show_collection_description":true,"show_collection_image":false,"color_scheme":"scheme-d591d5c0-f7af-4280-bd26-676a440a87d5"}},"custom_liquid_bcpxJT":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<section id=\"cp-hero\" class=\"color-scheme-1\">\n  <!-- Background video -->\n  <video class=\"cp-hero__video\" autoplay loop muted playsinline preload=\"metadata\" poster=\"\">\n    <!-- Dog bathrobe video -->\n    <source src=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/1976603818d94392bf963f0f3caeaa95.mp4\" type=\"video\/mp4\">\n  <\/video>\n\n  <div class=\"cp-hero__overlay\" aria-hidden=\"true\"><\/div>\n\n  <!-- Content -->\n  <div class=\"cp-hero__content page-width\">\n    <h1 class=\"cp-hero__title h0\">\n      <strong>Après le bain,<br>le confort commence.<\/strong>\n    <\/h1>\n\n    <p class=\"cp-hero__subtitle\">\n      Ultra-absorbant, doux et chaud — le peignoir CozzyPaws sèche votre chien en douceur\n      tout en protégeant votre maison.\n    <\/p>\n\n    <ul class=\"cp-hero__benefits\" role=\"list\">\n      <li><span class=\"cp-ico\">🐾<\/span> Sèche rapidement après la douche<\/li>\n      <li><span class=\"cp-ico\">🐾<\/span> Garde votre chien au chaud<\/li>\n      <li><span class=\"cp-ico\">🐾<\/span> Fini les sols et canapés mouillés<\/li>\n    <\/ul>\n  <\/div>\n\n  <style>\n    :root{\n      --cp-brand:#521010;\n      --cp-brand-hover:#732020;\n      --cp-light:#F1ECE6;\n    }\n\n    #cp-hero{\n      position: relative;\n      overflow: hidden;\n      padding-top: clamp(88px, 14vh, 140px);\n      padding-bottom: clamp(40px, 12vh, 120px);\n      background: var(--color-background);\n      color: var(--color-foreground);\n      isolation: isolate;\n    }\n\n    #cp-hero .cp-hero__video{\n      position: absolute;\n      inset: 0;\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      object-position