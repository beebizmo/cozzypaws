o__video');\n          if (v) {\n            v.removeAttribute('autoplay');\n            v.pause?.();\n          }\n        }\n      } catch(e){}\n    })();\n  <\/script>\n<\/section>","color_scheme":"scheme-d591d5c0-f7af-4280-bd26-676a440a87d5","padding_top":0,"padding_bottom":0}},"custom_liquid_LCPXVh":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<!-- REVIEW BAR SECTION -->\n<div class=\"cp-reviewbar\">\n  <span class=\"cp-reviewbar-logo\">COZZYPAWS<\/span>\n  <span class=\"cp-reviewbar-stars\">★★★★★<\/span>\n  <span class=\"cp-reviewbar-text\">\n    Noté <strong>4,9\/5<\/strong> par plus de <strong>450 maîtres<\/strong> au Maroc\n  <\/span>\n<\/div>\n\n<style>\n\/* -----------------------------------------\n   REVIEW BAR — LAYOUT\n----------------------------------------- *\/\n.cp-reviewbar {\n  position: relative;\n  margin: 0 auto;\n  margin-top: 0;\n  width: 90%;\n  max-width: 1400px;\n  height: 30px;\n\n  background: #521010;\n  border-radius: 0;\n\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 10px;\n\n  color: #ffffff;\n  font-size: 20px;\n  line-height: 1;\n  letter-spacing: 0.2px;\n\n  \/* Entrance animation *\/\n  opacity: 0;\n  transform: translateY(-8px);\n  animation: cp-bar-fade 0.9s ease-out forwards;\n  animation-delay: 0.3s;\n}\n\n\/* -----------------------------------------\n   ELEMENTS\n----------------------------------------- *\/\n.cp-reviewbar-logo {\n  font-weight: 600;\n  opacity: 0.95;\n  font-size: 13px;\n\n  \/* shimmer animation *\/\n  background: linear-gradient(90deg, #ffffff, #cccccc, #ffffff);\n  background-size: 200% auto;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  animation: cp-shimmer 4s linear infinite;\n}\n\n.cp-reviewbar-stars {\n  color: #ffb545;\n  font-size: 14px;\n  letter-spacing: 1px;\n\n  \/* sparkling\/pulsing stars *\/\n  animation: cp-stars-pulse 1.8s ease-in-out infinite;\n}\n\n.cp-reviewbar-text