 parfaitement conçu, il garde mon chien bien au chaud après le bain tout en restant confortable.\nUn produit à la fois chic et pratique 🐶✨\n            <\/p>\n            <div class=\"cp-rv__meta\">\n              <span class=\"cp-rv__verified\">✓<\/span><span>Client vérifié<\/span>\n            <\/div>\n          <\/div>\n        <\/article>\n\n        <article class=\"cp-rv\">\n          <div class=\"cp-rv__img\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0682\/2284\/5122\/files\/File_1.jpg?v=1770839571?v=1766190335\" alt=\"Avis Kenza\" loading=\"lazy\">\n          <\/div>\n          <div class=\"cp-rv__body\">\n            <div class=\"cp-rv__top\">\n              <div class=\"cp-rv__name\">priscille<\/div>\n              <div class=\"cp-rv__date\">12\/2025<\/div>\n            <\/div>\n            <div class=\"cp-rv__stars\" aria-label=\"5 étoiles sur 5\">\n              <span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span><span class=\"cp-star\">★<\/span>\n            <\/div>\n            <p class=\"cp-rv__text\">\n              Je l’utilise surtout après la douche et c’est devenu indispensable.\nMon chien ne mouille plus toute la maison et reste bien au chaud pendant que le peignoir absorbe l’humidité.\n            <\/p>\n            <div class=\"cp-rv__meta\">\n              <span class=\"cp-rv__verified\">✓<\/span><span>Client vérifié<\/span>\n            <\/div>\n          <\/div>\n        <\/article>\n\n        \n        \n\n      <\/div>\n\n      <button class=\"cp-realreviews__nav cp-realreviews__nav--next\" type=\"button\" aria-label=\"Avis suivants\">›<\/button>\n    <\/div>\n  <\/div>\n<\/section>\n\n<style>\n  \/* ===== Social proof hero (like screenshot) ===== *\/\n  .cp-socialproof{\n    padding: 64px 0;\n  \n    border-radius: 18px;\n  }\n  .cp-socialproof__wrap{\n    padding: 0 0;\n  }\n  .cp-socialproof__hero{\n    text-align:center;\n    padding: 22px 0 18px;\n  }\n  .cp-socialproof__num{\n    font-size: clamp(52px, 7vw, 110px);\n    font-weight: 900;\n    letter-spacing: -0.04em;\n    line-height: 0.95;\n    color: #111;\n  }\n  .cp-socialproof__line{\n    margin-top: 14px;\n    font-size: clamp(18px, 2.2vw, 28px);\n    font-weight: 700;\n    color: #111;\n    max-width: 760px;\n    margin-left:auto;\n    margin-right:auto;\n  }\n\n  \/* ===== Slider base ===== *\/\n  .cp-realreviews__slider{ position: relative; margin-top: 24px; }\n  .cp-realreviews__track{\n    display:flex;\n    gap: 16px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    scroll-behavior: smooth;\n    padding: 14px 56px;\n    scrollbar-width: none;\n    -webkit-overflow-scrolling: touch;\n  }\n  .cp-realreviews__track::-webkit-scrollbar{ display:none; }\n\n  \/* Cards *\/\n  .cp-rv{\n    flex: 0 0 520px;\n    scroll-snap-align: start;\n    border: 1px solid rgba(0,0,0,.10);\n    border-radius: 18px;\n    background: #fff;\n    overflow: hidden;\n    display: grid;\n    grid-template-columns: 42% 58%;\n    min-height: 240px;\n    box-shadow: 0 10px 24px rgba(0,0,0,.06);\n  }\n\n  .cp-rv__img{ background: rgba(0,0,0,.04); }\n  .cp-rv__img img{ width:100%; height:100%; object-fit: cover; display:block; }\n\n  .cp-rv__body{ padding: 16px 16px 14px; display:flex; flex-direction:column; gap: 10px; }\n  .cp-rv__top{ display:flex; align-items:center; justify-content:space-between; gap: 10px; }\n  .cp-rv__name{ font-weight: 900; color:#111; }\n  .cp-rv__date{ font-size: 12px; color: rgba(0,0,0,.55); }\n\n  .cp-rv__stars{ font-size: 14px; line-height: 1; }\n  .cp-star{ color: #f5a623; }\n\n  .cp-rv__text{\n    margin:0;\n    font-size: 14px;\n    line-height: 1.55;\n    color: rgba(0,0,0,.78);\n    display: -webkit-box;\n    -webkit-line-clamp: 5;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n  }\n\n  .cp-rv__meta{\n    margin-top: auto;\n    display:flex;\n    align-items:center;\n    gap: 8px;\n    font-size: 12px;\n    color: rgba(0,0,0,.62);\n  }\n  .cp-rv__verified{\n    width:18px;\n    height:18px;\n    border-radius: 999px;\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    background: rgba(0,0,0,.10);\n    color: rgba(0,0,0,.85);\n    font-size: 12px;\n    font-weight: 900;\n  }\n  .cp-rv__tag{ margin-left:auto; font-weight: 800; color: rgba(0,0,0,.62); }\n\n  \/* Nav buttons *\/\n  .cp-realreviews__nav{\n    position:absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 38px;\n    height: 38px;\n    border-radius: 999px;\n    border: 1px solid rgba(0,0,0,.14);\n    background: rgba(255,255,255,.95);\n    cursor:pointer;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-size: 22px;\n    line-height: 1;\n    box-shadow: 0 10px 24px rgba(0,0,0,.12);\n    z-index: 3;\n  }\n  .cp-realreviews__nav--prev{ left: 10px; }\n  .cp-realreviews__nav--next{ right: 10px; }\n\n  \/* ===== Rating card ===== *\/\n  .cp-rv--rating{\n    grid-template-columns: 1fr;\n    min-height: 240px;\n    background: transparent;\n  }\n  .cp-ratingcard{\n    height: 100%;\n    border-radius: 18px;\n    background: #521013; \/* muted green like screenshot *\/\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    gap: 10px;\n    padding: 18px;\n    text-align:center;\n  }\n  .cp-ratingcard__title{\n    font-weight: 900;\n    color:white;\n  }\n  .cp-ratingcard__stars{\n    color:#f5a623;\n    font-size: 18px;\n    letter-spacing: 2px;\n  }\n  .cp-ratingcard__meta{\n    color:#111;\n    opacity:.9;\n    font-size: 13px;\n    line-height: 1.2;\n  }\n  .cp-ratingcard__score strong{ font-size: 16px; }\n  .cp-ratingcard__brand{\n    margin-top: 2px;\n    font-weight: 900;\n    letter-spacing: .02em;\n    color:white;\n    opacity:.9;\n  }\n\n  @media (max-width: 989px){\n    .cp-socialproof{ padding: 46px 0; border-radius: 14px; }\n    .cp-realreviews__track{ padding: 12px 50px; }\n    .cp-rv{ flex-basis: 86vw; grid-template-columns: 1fr; }\n    .cp-rv__img img{ height: 220px; }\n  }\n<\/style>\n\n<script>\n(function(){\n  function init(root){\n    const track = root.querySelector('[data-cp-track]');\n    const prev  = root.querySelector('.cp-realreviews__nav--prev');\n    const next  = root.querySelector('.cp-realreviews__nav--next');\n    if(!track || !prev || !next) return;\n\n    const step = () => {\n      const card = track.querySelector('.cp-rv');\n      const gap = 16;\n      if(!card) return 520;\n      return card.getBoundingClientRect().width + gap;\n    };\n\n    prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));\n    next.addEventListener('click', () => track.scrollBy({ left:  step(), behavior: 'smooth' }));\n\n    \/\/ drag to scroll (desktop)\n    let isDown=false, startX=0, scrollLeft=0;\n    track.addEventListener('mousedown', (e)=>{ isDown=true; startX=e.pageX; scrollLeft=track.scrollLeft; });\n    window.addEventListener('mouseup', ()=>{ isDown=false; });\n    track.addEventListener('mouseleave', ()=>{ isDown=false; });\n    track.addEventListener('mousemove', (e)=>{\n      if(!isDown) return;\n      e.preventDefault();\n      const walk = (e.pageX - startX);\n      track.scrollLeft = scrollLeft - walk;\n    });\n  }\n\n  function boot(){\n    document.querySelectorAll('[data-cp-realreviews]').forEach(init);\n  }\n  if(document.readyState === 'loading'){\n    document.addEventListener('DOMContentLoaded', boot);\n  } else {\n    boot();\n  }\n  document.addEventListener('shopify:section:load', (e)=>{\n    const root = e.target && e.target.querySelector ? e.target.querySelector('[data-cp-realreviews]') : null;\n    if(root) init(root);\n  });\n})();\n<\/script>","color_scheme":"scheme-d591d5c0-f7af-4280-bd26-676a440a87d5","padding_top":0,"padding_bottom":0}},"custom_liquid_cfdHzf":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"