s{\n      font-size: 14px;\n      letter-spacing: 2px;\n      transform: translateY(-1px);\n    }\n\n    #seen-in .cp-ratingtext{\n      font-weight: 500;\n      opacity: .85;\n    }\n\n    \/* ====== Title ====== *\/\n    #seen-in .cp-title{\n      margin: 0 0 clamp(16px, 2.5vw, 12px);\n      font-weight: 500;\n      font-size: clamp(20px, 4vw, 0px);\n      letter-spacing: .2px;\n    }\n\n    \/* ====== Logos row ====== *\/\n    #seen-in .cp-logos{\n      display: grid;\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n      gap: clamp(18px, 3vw, 44px);\n      align-items: center;\n      max-width: 580px;\n      margin: 0 auto;\n    }\n\n    #seen-in .cp-logo{\n      display: grid;\n      place-items: center;\n      padding: 6px 4px;\n    }\n\n    #seen-in .cp-logo img{\n      width: min(240px, 100%);\n      height: auto;\n      object-fit: contain;\n      display: block;\n      \/* very subtle crisp look like screenshot *\/\n      filter: drop-shadow(0 1px 0 rgba(0,0,0,.06));\n    }\n\n    \/* ====== Mobile ====== *\/\n    @media (max-width: 749px){\n      #seen-in .cp-logos{\n        grid-template-columns: 1fr;\n        gap: 18px;\n      }\n\n      #seen-in .cp-logo img{\n        width: min(260px, 72vw);\n      }\n    }\n  <\/style>\n<\/section>","color_scheme":"scheme-d591d5c0-f7af-4280-bd26-676a440a87d5","padding_top":0,"padding_bottom":0}},"custom_liquid_fPG7eB":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<section id=\"cp-hero\" class=\"color-scheme-1\">\n  <!-- Background video -->\n  <video class=\"cp-hero__video\" autoplay loop muted playsinline preload=\"metadata\" poster=\"\">\n    <!-- Dog bathrobe video -->\n    <source src=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/1976603818d94392bf963f0f3caeaa95.mp4\" type=\"video\/mp4\">\n  <\/video>\n\n  <div class=\"cp-hero__overlay\" aria-hidden=\"true\"><\/div>\n\n  <!-- Content -->\n  <div class=\"cp-hero__content page-width\">\n    <h1 class=\"cp-hero__title h0\">\n      <strong>Après le bain,<br>le confort commence.<\/strong>\n    <\/h1>\n\n    <p class=\"cp-hero__subtitle\">\n      Ultra-absorbant, doux et chaud — le peignoir CozzyPaws sèche votre chien en douceur\n      tout en protégeant votre maison.\n    <\/p>\n\n    <ul class=\"cp-hero__benefits\" role=\"list\">\n      <li><span class=\"cp-ico\">🐾<\/span> Sèche rapidement après la douche<\/li>\n      <li><span class=\"cp-ico\">🐾<\/span> Garde votre chien au chaud<\/li>\n      <li><span class=\"cp-ico\">🐾<\/span> Fini les sols et canapés mouillés<\/li>\n    <\/ul>\n  <\/div>\n\n  <style>\n    :root{\n      --cp-brand:#521010;\n      --cp-brand-hover:#732020;\n      --cp-light:#F1ECE6;\n    }\n\n    #cp-hero{\n      position: relative;\n      overflow: hidden;\n      padding-top: clamp(88px, 14vh, 140px);\n      padding-bottom: clamp(40px, 12vh, 120px);\n      background: var(--color-background);\n      color: var(--color-foreground);\n      isolation: isolate;\n    }\n\n    #cp-hero .cp-hero__video{\n      position: absolute;\n      inset: 0;\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      object-position: center;\n      z-index: -2;\n    }\n\n    #cp-hero .cp-hero__overlay{\n      position: absolute;\n      inset: 0;\n      background: linear-gradient(\n        to top,\n        rgba(0,0,0,0.55) 0%,\n        rgba(0,0,0,0.35) 40%,\n        rgba(0,0,0,0.2) 100%\n      );\n      z-index: -1;\n    }\n\n    #cp-hero .cp-hero__content{\n      display: flex;\n      flex-direction: column;\n      align-items: flex-start;\n      justify-content: center;\n      gap: 1rem;\n      min-height: min(78vh, 760px);\n      max-width: 1200px;\n    }\n\n    #cp-hero .cp-hero__title{\n      margin: 0;\n      color: #fff;\n      letter-spacing: -0.02em;\n      line-height: 1.06;\n      text-shadow: 0 3px 18px rgba(0,0,0,0.6);\n      max-width: 18ch;\n    }\n\n    #cp-hero .cp-hero__subtitle{\n      margin: 0;\n      color: rgba(255,255,255,0.96);\n      text-shadow: 0 2px 12px rgba(0,0,0,0.55);\n      max-width: 55ch;\n    }\n\n    #cp-hero .cp-hero__benefits{\n      display: flex;\n      flex-wrap: wrap;\n      gap: .4rem;\n      margin: .75rem 0 0;\n      padding: 0;\n    }\n\n    #cp-hero .cp-hero__benefits li{\n      list-style: none;\n      display: inline-flex;\n      align-items: center;\n      gap: .5rem;\n      padding: .5rem .75rem;\n      border-radius: 999px;\n      border: 1px solid rgba(255,255,255,.28);\n      background: rgba(255,255,255,1);\n      backdrop-filter: blur(2px);\n      font-size: .9375rem;\n      line-height: 1.2;\n      white-space: nowrap;\n      color: #521010;\n    }\n\n    #cp-hero .cp-ico{\n      font-size: 1.4rem;\n      line-height: 1;\n    }\n\n    @media (max-width: 749px){\n      #cp-hero .cp-hero__content{\n        align-items: center;\n        text-align: center;\n      }\n      #cp-hero .cp-hero__benefits li{\n        white-space: normal;\n      }\n    }\n  <\/style>\n\n  <script>\n    (() => {\n      try {\n        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {\n          const v = document.querySelector('#cp-hero .cp-hero__video');\n          if (v) {\n            v.removeAttribute('autoplay');\n            v.pause?.();\n          }\n        }\n      } catch(e){}\n    })();\n  <\/script>\n<\/section>","color_scheme":"scheme-d591d5c0-f7af-4280-bd26-676a440a87d5","padding_top":0,"padding_bottom":0}},"custom_liquid_trcqXR":{"type":"custom-liquid","name":"event","settings":{"custom_liquid":"<!-- ====== CozzyPaws — Trust Events Gallery (Combined, modern) ====== -->\n<section class=\"cp-trust-events color-background-1\" data-cp-trust-events>\n  <div class=\"page-width\">\n\n    <div class=\"cp-trust-events__header\">\n      \n      <h2 class=\"cp-trust-events__title\">Ils nous ont vus en vrai 🐾<\/h2>\n      <p class=\"cp-trust-events__subtitle\">\n        CozzyPaws, une marque à l’écoute de ses clients, testée dans la vraie vie.\n      <\/p>\n  