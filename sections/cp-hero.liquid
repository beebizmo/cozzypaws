{{ 'cp-premium.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign hero_image = section.settings.image
  assign hero_video = section.settings.video
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
-%}

<section
  class="cp-hero{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade{% endif %}"
  id="cp-hero-{{ section.id }}"
  aria-label="{{ section.settings.heading | default: shop.name | escape }}"
>
  {%- comment %} ── BACKGROUND MEDIA ── {% endcomment -%}
  <div class="cp-hero__media" aria-hidden="true">
    {%- if hero_image != blank -%}
      {{
        hero_image
        | image_url: width: 2000
        | image_tag:
          class: 'cp-hero__img',
          widths: '750, 1100, 1500, 1780, 2000',
          sizes: '100vw',
          fetchpriority: 'high',
          loading: 'eager',
          alt: section.settings.heading | default: shop.name | escape
      }}
    {%- else -%}
      <div class="cp-hero__placeholder"></div>
    {%- endif -%}
    <div class="cp-hero__overlay" style="opacity: {{ overlay_opacity }};"></div>
  </div>

  {%- comment %} ── CONTENT ── {% endcomment -%}
  <div class="cp-hero__content cp-hero__content--{{ section.settings.text_align }}">
    <div class="page-width cp-hero__inner">

      {%- if section.settings.eyebrow != blank -%}
        <p class="cp-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="cp-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="cp-hero__sub">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <div class="cp-hero__ctas">
          <a
            href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}"
            class="button cp-hero__cta-primary"
          >
            {{ section.settings.cta_label | escape }}
          </a>
          {%- if section.settings.cta2_label != blank -%}
            <a
              href="{{ section.settings.cta2_url | default: routes.all_products_collection_url }}"
              class="button button--secondary cp-hero__cta-secondary"
            >
              {{ section.settings.cta2_label | escape }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_social_proof -%}
        <div class="cp-hero__proof">
          <div class="cp-hero__stars" aria-hidden="true">★★★★★</div>
          <p class="cp-hero__proof-text">
            <strong>+450 avis 5 étoiles</strong> de familles marocaines satisfaites
          </p>
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- comment %} ── SCROLL INDICATOR ── {% endcomment -%}
  {%- if section.settings.show_scroll -%}
    <div class="cp-hero__scroll" aria-hidden="true">
      <div class="cp-hero__scroll-dot"></div>
    </div>
  {%- endif -%}

</section>

<style>
  .cp-hero {
    position: relative;
    min-height: {{ section.settings.min_height_mobile }}px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--cp-cream-dark);
  }

  @media screen and (min-width: 750px) {
    .cp-hero {
      min-height: {{ section.settings.min_height_desktop }}px;
    }
  }
</style>

{% schema %}
{
  "name": "CP — Hero",
  "tag": "section",
  "class": "cp-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay darkness",
      "default": 35
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "label": "Height (desktop)",
      "default": 650
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "label": "Height (mobile)",
      "default": 500
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "🐾 La marque préférée des familles marocaines"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Vos animaux méritent <em>le meilleur confort</em></p>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Séchez, chouchoutez et prenez soin de votre compagnon avec nos produits premium"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Découvrir la collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Button label",
      "default": "Notre histoire"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Options"
    },
    {
      "type": "checkbox",
      "id": "show_social_proof",
      "label": "Show star rating bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_scroll",
      "label": "Show scroll indicator",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "CP — Hero"
    }
  ]
}
{% endschema %}
