{{ 'cp-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .cp-benefits-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    .cp-benefits-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.65 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.65 | round }}px;
    }
  }
{%- endstyle -%}

<section
  class="cp-benefits-section cp-benefits-section-{{ section.id }} color-{{ section.settings.color_scheme }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
  id="cp-benefits-{{ section.id }}"
>
  <div class="page-width">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="cp-benefits__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="cp-benefits__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="cp-benefits__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="cp-benefits__sub">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment %} BEFORE / AFTER image pair + benefit list -%}{% endcomment -%}
    <div class="cp-benefits__layout cp-benefits__layout--{{ section.settings.layout }}">

      {%- comment %} Image side -%}{% endcomment -%}
      {%- if section.settings.image != blank -%}
        <div class="cp-benefits__media{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{
            section.settings.image
            | image_url: width: 900
            | image_tag:
              class: 'cp-benefits__img',
              widths: '450, 600, 750, 900',
              sizes: '(min-width: 990px) 45vw, 100vw',
              loading: 'lazy',
              alt: section.settings.heading | escape
          }}
          {%- if section.settings.image_badge != blank -%}
            <div class="cp-benefits__img-badge">{{ section.settings.image_badge | escape }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment %} Benefits list -%}{% endcomment -%}
      <div class="cp-benefits__list{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'benefit' -%}
              <div class="cp-benefits__item" {{ block.shopify_attributes }}>
                <div class="cp-benefits__item-icon" aria-hidden="true">
                  {%- if block.settings.icon_emoji != blank -%}
                    <span class="cp-benefits__emoji">{{ block.settings.icon_emoji }}</span>
                  {%- else -%}
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  {%- endif -%}
                </div>
                <div class="cp-benefits__item-body">
                  {%- if block.settings.heading != blank -%}
                    <h3 class="cp-benefits__item-title">{{ block.settings.heading | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <p class="cp-benefits__item-text">{{ block.settings.text | escape }}</p>
                  {%- endif -%}
                </div>
              </div>

            {%- when 'stat' -%}
              <div class="cp-benefits__stat" {{ block.shopify_attributes }}>
                <span class="cp-benefits__stat-number">{{ block.settings.number | escape }}</span>
                <span class="cp-benefits__stat-label">{{ block.settings.label | escape }}</span>
              </div>

          {%- endcase -%}
        {%- endfor -%}

        {%- if section.settings.cta_label != blank -%}
          <div class="cp-benefits__cta-wrap">
            <a
              href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}"
              class="button"
            >
              {{ section.settings.cta_label | escape }}
            </a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "CP — Product Benefits",
  "tag": "section",
  "class": "cp-benefits-section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image-left", "label": "Image left" },
        { "value": "image-right", "label": "Image right" }
      ],
      "default": "image-left"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Pourquoi CozzyPaws ?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sèche 5× plus vite qu'une serviette ordinaire"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Conçu pour les chiens actifs, approuvé par leurs familles"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "image_badge",
      "label": "Image badge text",
      "default": "🏆 #1 au Maroc"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Commander maintenant"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit item",
      "settings": [
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Emoji icon",
          "info": "Leave blank for checkmark icon",
          "default": "⚡"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Benefit title",
          "default": "Séchage ultra-rapide"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Benefit description",
          "default": "Microfibre haute densité — sèche votre chien en moins de 5 minutes"
        }
      ]
    },
    {
      "type": "stat",
      "name": "Stat number",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "+450"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Clients satisfaits"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CP — Product Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon_emoji": "⚡",
            "heading": "Séchage ultra-rapide",
            "text": "Microfibre haute densité — sèche votre chien en 5 min chrono"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_emoji": "🌿",
            "heading": "Matière douce et sûre",
            "text": "Sans produits chimiques, respectueux de la peau sensible de votre animal"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_emoji": "🧺",
            "heading": "Lavable en machine",
            "text": "Résiste à des centaines de lavages sans perdre ses propriétés"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon_emoji": "📐",
            "heading": "Toutes les tailles",
            "text": "Du chihuahua au labrador — trouvez la taille parfaite pour votre chien"
          }
        }
      ]
    }
  ]
}
{% endschema %}
