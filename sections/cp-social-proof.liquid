        },
        {
          "type": "stat",
          "settings": { "number": "48h", "label": "Livraison rapide" }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "Le sac de séchage est incroyable ! Mon labrador est sec en 5 minutes. Je recommande à 100% !",
            "name": "Fatima B.",
