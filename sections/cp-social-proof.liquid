{{ 'cp-premium.css' | asset_url | stylesheet_tag }}

<section
  class="cp-social-proof color-{{ section.settings.color_scheme }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
  id="cp-social-proof-{{ section.id }}"
  aria-label="Avis clients"
>
  <div class="page-width">

    {%- comment %} ── STATS BAR ── {% endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="cp-sp__stats" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="cp-sp__stat" role="listitem" {{ block.shopify_attributes }}>
              <span class="cp-sp__stat-number">{{ block.settings.number | escape }}</span>
              <span class="cp-sp__stat-label">{{ block.settings.label | escape }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment %} ── SECTION HEADING ── {% endcomment -%}
    {%- if section.settings.heading != blank -%}
      <div class="cp-sp__header">
        <h2 class="cp-sp__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="cp-sp__sub">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment %} ── REVIEW CARDS ── {% endcomment -%}
    {%- assign review_blocks = section.blocks | where: 'type', 'review' -%}
    {%- if review_blocks.size > 0 -%}
      <div class="cp-sp__reviews" role="list" aria-label="Témoignages clients">
        {%- for block in review_blocks -%}
          <article class="cp-sp__review" role="listitem" {{ block.shopify_attributes }}>
            <div class="cp-sp__review-stars" aria-label="{{ block.settings.rating }} étoiles sur 5">
              {%- for i in (1..block.settings.rating) -%}★{%- endfor -%}
            </div>
            {%- if block.settings.text != blank -%}
              <blockquote class="cp-sp__review-text">
                "{{ block.settings.text | escape }}"
              </blockquote>
            {%- endif -%}
            <footer class="cp-sp__review-author">
              {%- if block.settings.avatar != blank -%}
                {{
                  block.settings.avatar
                  | image_url: width: 80
                  | image_tag:
                    class: 'cp-sp__avatar',
                    width: 40,
                    height: 40,
                    loading: 'lazy',
                    alt: block.settings.name | escape
                }}
              {%- else -%}
                <div class="cp-sp__avatar-placeholder" aria-hidden="true">
                  {{ block.settings.name | slice: 0 | upcase }}
                </div>
              {%- endif -%}
              <div>
                <strong class="cp-sp__author-name">{{ block.settings.name | escape }}</strong>
                {%- if block.settings.location != blank -%}
                  <span class="cp-sp__author-loc">{{ block.settings.location | escape }}</span>
                {%- endif -%}
              </div>
              {%- if block.settings.verified -%}
                <span class="cp-sp__verified" title="Achat vérifié">✓ Vérifié</span>
              {%- endif -%}
            </footer>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="cp-sp__cta-wrap">
        <a href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}" class="button button--secondary">
          {{ section.settings.cta_label | escape }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "CP — Social Proof",
  "tag": "section",
  "class": "cp-social-proof-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-095c3560-da68-4939-b41f-087b8dd43596"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p><strong>Des toutous heureux, des maisons propres !</strong></p>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Ce que nos clients disent de CozzyPaws"
