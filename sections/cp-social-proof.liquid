        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Casablanca, Maroc"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar photo (optional)"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CP — Social Proof",
      "blocks": [
        {
