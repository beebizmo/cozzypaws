{% comment %}
  Guarantee Strip — CozzyPaws
  Displays inline trust signals directly above or below the ATC button.
  Compact, icon-based, high-trust signal for product pages.

  Usage:
    {% render 'guarantee-strip' %}
{% endcomment %}

<div class="cp-guarantee-strip" role="list" aria-label="Nos garanties">
  <div class="cp-guarantee-strip__item" role="listitem">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
    Livraison rapide
  </div>

  <span class="cp-guarantee-strip__divider" aria-hidden="true"></span>

  <div class="cp-guarantee-strip__item" role="listitem">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
    Retour 30 jours
  </div>

  <span class="cp-guarantee-strip__divider" aria-hidden="true"></span>

  <div class="cp-guarantee-strip__item" role="listitem">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    </svg>
    Paiement sécurisé
  </div>

  <span class="cp-guarantee-strip__divider" aria-hidden="true"></span>

  <div class="cp-guarantee-strip__item" role="listitem">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
    Support WhatsApp
  </div>
</div>
