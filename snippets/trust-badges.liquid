{% comment %}
  Trust Badges Strip — CozzyPaws
  Usage: {% render 'trust-badges', style: 'horizontal' %}
  Params:
    style: 'horizontal' (default) | 'vertical'
    show_text: true (default) | false
{% endcomment %}

{%- liquid
  assign tb_style = style | default: 'horizontal'
  assign tb_show_text = show_text | default: true
-%}

<div class="cp-trust-badges cp-trust-badges--{{ tb_style }}" aria-label="Nos garanties">
  <div class="cp-trust-badges__item">
    <span class="cp-trust-badges__icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </span>
    {%- if tb_show_text -%}
    <span class="cp-trust-badges__text">
      <strong>Livraison rapide</strong>
      <small>Partout au Maroc</small>
    </span>
    {%- endif -%}
  </div>

  <div class="cp-trust-badges__item">
    <span class="cp-trust-badges__icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
      </svg>
    </span>
    {%- if tb_show_text -%}
    <span class="cp-trust-badges__text">
      <strong>Paiement sécurisé</strong>
      <small>CB & Paiement à la livraison</small>
    </span>
    {%- endif -%}
  </div>

  <div class="cp-trust-badges__item">
    <span class="cp-trust-badges__icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="1 4 1 10 7 10"/>
        <path d="M3.51 15a9 9 0 1 0 .49-3.67"/>
      </svg>
    </span>
    {%- if tb_show_text -%}
    <span class="cp-trust-badges__text">
      <strong>Retour facile</strong>
      <small>Sous 30 jours</small>
    </span>
    {%- endif -%}
  </div>

  <div class="cp-trust-badges__item">
    <span class="cp-trust-badges__icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </span>
    {%- if tb_show_text -%}
    <span class="cp-trust-badges__text">
      <strong>Fait avec amour</strong>
      <small>Pour vos animaux</small>
    </span>
    {%- endif -%}
  </div>
</div>
